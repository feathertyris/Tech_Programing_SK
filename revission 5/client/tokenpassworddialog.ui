<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TokenPasswordDialog</class>
 <widget class="QDialog" name="TokenPasswordDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>450</width>
    <height>520</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Reset Password</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QDialog {
        background-color: #0F0F0F;
    }
    QLabel {
        color: white;
        font-size: 14px;
    }
    QLineEdit {
        background-color: #2A2A2A;
        border: 1px solid #404040;
        padding: 10px;
        border-radius: 8px;
        color: white;
    }
    QPushButton {
        background-color: #3A82F7;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: bold;
    }
    QPushButton:hover {
        background-color: #2C65BF;
    }
   </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <item>
    <widget class="QFrame" name="cardFrame">
     <property name="styleSheet">
      <string notr="true">
       QFrame {
           background-color: #1A1A1A;
           border-radius: 16px;
           padding: 30px;
       }
      </string>
     </property>
     <layout class="QVBoxLayout" name="cardLayout">
      <!-- Заголовок -->
      <item>
       <widget class="QLabel" name="titleLabel">
        <property name="styleSheet">
         <string notr="true">font-size: 24px; font-weight: bold; color: white;</string>
        </property>
        <property name="text">
         <string>Восстановление пароля</string>
        </property>
        <property name="alignment">
         <set>Qt::AlignmentFlag::AlignCenter</set>
        </property>
       </widget>
      </item>

      <!-- Метка с email -->
      <item>
       <widget class="QLabel" name="emailLabel">
        <property name="text">
         <string>Email: </string>
        </property>
        <property name="alignment">
         <set>Qt::AlignmentFlag::AlignCenter</set>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>

      <!-- Поле ввода кода -->
      <item>
       <widget class="QLineEdit" name="codeEdit">
        <property name="placeholderText">
         <string>6‑значный код из письма</string>
        </property>
        <property name="maxLength">
         <number>6</number>
        </property>
        <property name="inputMask">
         <string>999999</string>
        </property>
       </widget>
      </item>

      <!-- Поле ввода нового пароля -->
      <item>
       <widget class="QLineEdit" name="newPasswordEdit">
        <property name="echoMode">
         <enum>QLineEdit::Password</enum>
        </property>
        <property name="placeholderText">
         <string>Новый пароль (минимум 6 символов)</string>
        </property>
       </widget>
      </item>

      <!-- Кнопка сброса пароля -->
      <item>
       <widget class="QPushButton" name="resetPasswordButton">
        <property name="text">
         <string>Сбросить пароль</string>
        </property>
       </widget>
      </item>

      <!-- Статусная метка -->
      <item>
       <widget class="QLabel" name="statusLabel">
        <property name="styleSheet">
         <string notr="true">color: #FF6B6B;</string>
        </property>
        <property name="text">
         <string/>
        </property>
        <property name="alignment">
         <set>Qt::AlignmentFlag::AlignCenter</set>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
