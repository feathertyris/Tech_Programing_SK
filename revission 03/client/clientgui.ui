<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ClientGUI</class>
 <widget class="QMainWindow" name="ClientGUI">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1000</width>
    <height>700</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Клиент построения графиков — Система функций</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <layout class="QVBoxLayout" name="verticalLayout">
    <item>
     <widget class="QGroupBox" name="groupBoxConnection">
      <property name="title">
       <string>① Подключение к серверу</string>
      </property>
      <layout class="QHBoxLayout" name="horizontalLayoutConnection">
       <item>
        <widget class="QLabel" name="labelHost">
         <property name="text">
          <string>Хост:</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLineEdit" name="hostEdit">
         <property name="text">
          <string>localhost</string>
         </property>
         <property name="placeholderText">
          <string>Введите IP или localhost</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="labelPort">
         <property name="text">
          <string>Порт:</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLineEdit" name="portEdit">
         <property name="text">
          <string>33333</string>
         </property>
         <property name="placeholderText">
          <string>Номер порта</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="connectButton">
         <property name="text">
          <string>Подключиться</string>
         </property>
         <property name="styleSheet">
          <string notr="true">QPushButton {
    background-color: #4CAF50;
    color: white;
    border: none;
    padding: 8px 16px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #45a049;
}</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="groupBoxFunction">
      <property name="title">
       <string>② Параметры функции f(x)</string>
      </property>
      <layout class="QGridLayout" name="gridLayoutFunction">
       <!-- Строка 1: Параметры a, b, c -->
       <item row="0" column="0">
        <widget class="QLabel" name="labelA">
         <property name="text">
          <string>a (∛x + a):</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QDoubleSpinBox" name="aSpinBox">
         <property name="decimals">
          <number>2</number>
         </property>
         <property name="minimum">
          <double>-50.00</double>
         </property>
         <property name="maximum">
          <double>50.00</double>
         </property>
         <property name="value">
          <double>1.00</double>
         </property>
        </widget>
       </item>
       <item row="0" column="2">
        <widget class="QLabel" name="labelB">
         <property name="text">
          <string>b (1/x - b):</string>
         </property>
        </widget>
       </item>
       <item row="0" column="3">
        <widget class="QDoubleSpinBox" name="bSpinBox">
         <property name="decimals">
          <number>2</number>
         </property>
         <property name="minimum">
          <double>-50.00</double>
         </property>
         <property name="maximum">
          <double>50.00</double>
         </property>
         <property name="value">
          <double>0.00</double>
         </property>
        </widget>
       </item>
       <item row="0" column="4">
        <widget class="QLabel" name="labelC">
         <property name="text">
          <string>c (x² - cx + 1):</string>
         </property>
        </widget>
       </item>
       <item row="0" column="5">
        <widget class="QDoubleSpinBox" name="cSpinBox">
         <property name="decimals">
          <number>2</number>
         </property>
         <property name="minimum">
          <double>-50.00</double>
         </property>
         <property name="maximum">
          <double>50.00</double>
         </property>
         <property name="value">
          <double>0.00</double>
         </property>
        </widget>
       </item>

       <!-- Строка 2: Диапазон X -->
       <item row="1" column="0">
        <widget class="QLabel" name="labelXStart">
         <property name="text">
          <string>X начало:</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QDoubleSpinBox" name="xStartSpinBox">
         <property name="decimals">
          <number>1</number>
         </property>
         <property name="minimum">
          <double>-100.0</double>
         </property>
         <property name="maximum">
          <double>0.0</double>
         </property>
         <property name="value">
          <double>-10.0</double>
         </property>
        </widget>
       </item>
       <item row="1" column="2">
        <widget class="QLabel" name="labelXEnd">
         <property name="text">
          <string>X конец:</string>
         </property>
        </widget>
       </item>
       <item row="1" column="3">
        <widget class="QDoubleSpinBox" name="xEndSpinBox">
         <property name="decimals">
          <number>1</number>
         </property>
         <property name="minimum">
          <double>0.0</double>
         </property>
         <property name="maximum">
          <double>100.0</double>
         </property>
         <property name="value">
          <double>10.0</double>
         </property>
        </widget>
       </item>
       <item row="1" column="4">
        <widget class="QLabel" name="labelXStep">
         <property name="text">
          <string>Шаг X:</string>
         </property>
        </widget>
       </item>
       <item row="1" column="5">
        <widget class="QDoubleSpinBox" name="xStepSpinBox">
         <property name="decimals">
          <number>3</number>
         </property>
         <property name="minimum">
          <double>0.01</double>
         </property>
         <property name="maximum">
          <double>10.0</double>
         </property>
         <property name="value">
          <double>0.1</double>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QPushButton" name="calculateButton">
      <property name="text">
      <string>③ Рассчитать график</string>
      </property>
      <property name="styleSheet">
       <string notr="true">QPushButton {
    background-color: #2196F3;
    color: white;
    border: none;
    padding: 10px 20px;
    font-weight: bold;
    font-size: 14px;
}
QPushButton:hover {
    background-color: #0b7dda;
}</string>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QLabel" name="statusLabel">
      <property name="text">
       <string>Статус: не подключено</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignCenter</set>
      </property>
      <property name="styleSheet">
       <string notr="true">QLabel {
    color: #666;
    font-weight: bold;
    padding: 8px;
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 4px;
}</string>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="groupBoxChart">
      <property name="title">
       <string>④ График функций</string>
      </property>
      <layout class="QVBoxLayout" name="verticalLayoutChart">
       <item>
        <widget class="QWidget" name="chartContainer">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
           <horstretch>0</horstretch>
           <verstretch>0</verstretch>
          </sizepolicy>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
