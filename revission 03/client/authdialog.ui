<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>AuthDialog</class>
 <widget class="QDialog" name="AuthDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>300</width>
    <height>280</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Авторизация / Регистрация</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QDialog {
        background: #f8f9fa; /* светло‑серый фон */
    }
    QLabel {
        color: #212121; /* тёмно‑серый текст */
        font-weight: bold;
    }
   </string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <property name="spacing">
    <number>15</number>
   </property>
   <property name="margin">
    <number>20</number>
   </property>
   <item>
    <widget class="QLabel" name="titleLabel">
     <property name="text">
      <string>Добро пожаловать!</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
     <property name="styleSheet">
      <string notr="true">QLabel {
          font-size: 18px;
          font-weight: bold;
          color: #212121;
      }</string>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QGridLayout" name="gridLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="labelUsername">
       <property name="text">
        <string>Логин:</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QLineEdit" name="usernameEdit">
       <property name="placeholderText">
        <string>Введите логин</string>
       </property>
       <property name="styleSheet">
        <string notr="true">QLineEdit {
            border: 2px solid #4CAF50;
            border-radius: 8px;
            padding: 5px;
            background: white;
        }</string>
       </property>
      </widget>
     </item>
     <item row="1" column="0">
      <widget class="QLabel" name="labelPassword">
       <property name="text">
        <string>Пароль:</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1">
      <widget class="QLineEdit" name="passwordEdit">
       <property name="echoMode">
        <enum>QLineEdit::Password</enum>
       </property>
       <property name="placeholderText">
        <string>Введите пароль</string>
       </property>
       <property name="styleSheet">
        <string notr="true">QLineEdit {
            border: 2px solid #2196F3;
            border-radius: 8px;
            padding: 5px;
            background: white;
        }</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="buttonLayout">
     <item>
      <widget class="QPushButton" name="loginButton">
       <property name="text">
        <string>Войти</string>
       </property>
       <property name="styleSheet">
        <string notr="true">QPushButton {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 8px;
            font-weight: bold;
        }
        QPushButton:hover {
            background-color: #45a049;
        }</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="registerButton">
       <property name="text">
        <string>Зарегистрироваться</string>
       </property>
       <property name="styleSheet">
        <string notr="true">QPushButton {
            background-color: #2196F3;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 8px;
            font-weight: bold;
        }
        QPushButton:hover {
            background-color: #0b7dda;
        }</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <!-- Добавленная кнопка восстановления пароля -->
   <item>
    <widget class="QPushButton" name="recoveryButton">
     <property name="text">
      <string>Восстановить пароль</string>
     </property>
     <property name="styleSheet">
      <string notr="true">QPushButton {
          background-color: #FF9800; /* оранжевый цвет для кнопки восстановления */
          color: white;
          border: none;
          padding: 8px 16px;
          border-radius: 8px;
          font-weight: bold;
      }
      QPushButton:hover {
          background-color: #e68900; /* затемнённый оранжевый при наведении */
      }</string>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
