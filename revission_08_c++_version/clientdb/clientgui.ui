   <string notr="true">
    QMainWindow {
        background-color: #0F0F0F;
    }
    QLabel {
        color: white;
        font-size: 11px;
    }
    QLineEdit, QDoubleSpinBox {
        background-color: #2A2A2A;
        border: 1px solid #404040;
        padding: 3px 5px;
        border-radius: 4px;
        color: white;
        font-size: 10px;
    }
    QSlider::groove:horizontal {
        height: 4px;
        background: #404040;
        border-radius: 2px;
    }
    QSlider::handle:horizontal {
        background: #3A82F7;
        width: 12px;
        height: 12px;
        margin: -4px 0;
        border-radius: 6px;
    }
    QSlider::handle:horizontal:hover {
        background: #2C65BF;
    }
    QSlider::sub-page:horizontal {
        background: #3A82F7;
        border-radius: 2px;
    }
    QGroupBox {
        color: white;
        font-weight: bold;
        border: 1px solid #404040;
        border-radius: 6px;
        margin-top: 12px;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 8px;
        padding: 0 5px 0 5px;
    }
    QPushButton {
        background-color: #3A82F7;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 5px;
        font-weight: bold;
        font-size: 11px;
    }
    QPushButton:hover {
        background-color: #2C65BF;
    }
    QPushButton#calculateTripleButton {
        background-color: #28A745;
    }
    QPushButton#calculateTripleButton:hover {
